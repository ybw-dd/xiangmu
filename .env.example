# ========================================
# 灵讯（LingXun）环境变量配置
# ========================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=lingxun123
MYSQL_DATABASE=lingxun
MYSQL_USER=lingxun
MYSQL_PASSWORD=lingxun123
MYSQL_PORT=3306

# ---- 数据库连接 ----
DATABASE_URL="mysql://lingxun:lingxun123@localhost:3306/lingxun"

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=lingxun123

# ---- JWT ----
JWT_SECRET=lingxun-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=lingxun-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ---- 服务端 ----
SERVER_PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ---- 前端 ----
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ---- Nginx ----
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ---- 文件上传 ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# ---- AI ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Elasticsearch ----
ELASTICSEARCH_URL=http://localhost:9200

# ---- 时区 ----
TZ=Asia/Shanghai
