# ========================================
# 灵讯（LingXun）生产环境变量（无域名 / HTTP 模式）
# 部署到服务器 123.57.146.197 时使用
# ========================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=lingxun123
MYSQL_DATABASE=lingxun
MYSQL_USER=lingxun
MYSQL_PASSWORD=lingxun123
MYSQL_PORT=3306

# ---- Redis ----
REDIS_PORT=6379
REDIS_PASSWORD=lingxun123

# ---- JWT ----
JWT_SECRET=lingxun-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=lingxun-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ---- 服务端 ----
NODE_ENV=production
CORS_ORIGIN=http://123.57.146.197:8080

# ---- 前端 ----
# NEXT_PUBLIC_* 在构建时内联，修改后需重新 build
NEXT_PUBLIC_API_URL=http://123.57.146.197:8080/api
NEXT_PUBLIC_WS_URL=ws://123.57.146.197:8080

# ---- Nginx（外部 8080 → 内部 80，避免与 todo 项目 80/3000 冲突）----
NGINX_HTTP_PORT=8080
# HTTPS 端口已禁用（无域名场景）

# ---- AI ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- 时区 ----
TZ=Asia/Shanghai